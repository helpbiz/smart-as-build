{
  "expo": {
    "name": "고짱 기사용",
    "slug": "smart-as-technician",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "extra": {
      "eas": {
        "projectId": "smart-as-technician"
      },
      "apiUrl": "http://foryouelec.co.kr:8080/api/v1"
    },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#34C759"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartas.technician"
    },
    "android": {
      "package": "com.smartas.technician",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-asset"
    ]
  }
}
