{
  "expo": {
    "name": "고짱 고객용",
    "slug": "smart-as-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "extra": {
      "eas": {
        "projectId": "smart-as-customer"
      },
      "apiUrl": "http://foryouelec.co.kr/api/v1"
    },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#007AFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartas.customer"
    },
    "android": {
      "package": "com.smartas.customer",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE", "ACCESS_FINE_LOCATION"]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Smart A/S to use your location for finding nearby technicians."
        }
      ]
    ]
  }
}
